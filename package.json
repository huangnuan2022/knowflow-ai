{
  "name": "knowflow",
  "version": "0.1.0",
  "private": true,
  "description": "KnowFlow NestJS backend foundation.",
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "db:down": "docker compose down",
    "db:ensure:test": "docker compose exec -T postgres sh -c \"psql -U knowflow -d postgres -tc \\\"SELECT 1 FROM pg_database WHERE datname = 'knowflow_test'\\\" | grep -q 1 || createdb -U knowflow knowflow_test\"",
    "db:migrate": "DATABASE_URL=${DATABASE_URL:-postgresql://knowflow:knowflow@localhost:15432/knowflow?schema=public} prisma migrate deploy",
    "db:migrate:test": "npm run db:ensure:test && DATABASE_URL=${TEST_DATABASE_URL:-postgresql://knowflow:knowflow@localhost:15432/knowflow_test?schema=public} prisma migrate deploy",
    "db:up": "docker compose up -d --wait postgres",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "prisma:generate": "prisma generate",
    "prisma:validate": "DATABASE_URL=${DATABASE_URL:-postgresql://knowflow:knowflow@localhost:15432/knowflow?schema=public} prisma validate",
    "test": "jest --runInBand",
    "test:integration": "DATABASE_URL=${TEST_DATABASE_URL:-postgresql://knowflow:knowflow@localhost:15432/knowflow_test?schema=public} jest --runInBand --testRegex '.*\\.integration-test\\.ts$'"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/mapped-types": "^2.1.0",
    "@nestjs/platform-express": "^11.0.0",
    "@prisma/client": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "openai": "^6.35.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.0",
    "jest": "^29.7.0",
    "prisma": "^6.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.2"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "src/**/*.(t|j)s"
    ],
    "testEnvironment": "node"
  }
}
