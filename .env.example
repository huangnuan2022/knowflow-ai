DATABASE_URL="postgresql://knowflow:knowflow@localhost:15432/knowflow?schema=public"
TEST_DATABASE_URL="postgresql://knowflow:knowflow@localhost:15432/knowflow_test?schema=public"
PORT=3000
CORS_ORIGIN="http://localhost:5173,http://127.0.0.1:5173"
VITE_API_BASE_URL="http://localhost:3000/api"

# Backend-owned AI defaults. Keep local/demo runs on stub unless you intentionally
# enable OpenAI with a server-side API key.
AI_PROVIDER="stub"
AI_MODEL="stub-tutor-v0"
AI_RUN_RATE_LIMIT_MAX="10"
AI_RUN_RATE_LIMIT_WINDOW_MS="60000"

# Required only when executing runs with AI_PROVIDER="openai" or provider="openai".
# Never expose this value to the frontend or commit a real secret.
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-5.4-mini"
